# Credence environment template
# Copy to .env.local and fill values as needed.

NEXT_PUBLIC_POLYMARKET_GAMMA_URL="https://gamma-api.polymarket.com"
NEXT_PUBLIC_POLYMARKET_CLOB_URL="https://clob.polymarket.com"

# Polygon RPC. Public fallback works for dev, Alchemy is recommended for stability.
NEXT_PUBLIC_POLYGON_RPC_URL="https://polygon-rpc.com"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Credence"

# D4 live trading kill switch.
# Default is false: order form only validates the path and will not submit CLOB orders.
# Set to true only with a clean low-balance wallet. D4 caps live orders at 1 pUSD.
NEXT_PUBLIC_ENABLE_REAL_TRADING="false"

# Geo block, enforced through Cloudflare CF-IPCountry header in production.
# Leave empty in local dev. Example high-risk jurisdictions:
# GEO_BLOCK_COUNTRIES="US,GB,SG,JP,KR,FR"
GEO_BLOCK_COUNTRIES=""

# Optional analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Optional Supabase, D8+
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Optional Telegram Bot, D8+
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_WEBHOOK_SECRET=""
